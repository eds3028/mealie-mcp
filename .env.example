# Base URL of your Mealie instance (no trailing slash).
# Local Docker example:    http://localhost:9011
# docker-compose service:  http://mealie:9000
MEALIE_URL=http://localhost:9011

# Long-lived API token. Create one in the Mealie UI under
# User Profile -> API Tokens.
MEALIE_API_TOKEN=replace-me

# Transport for the MCP server. "stdio" (Claude Desktop subprocess) or
# "sse" (HTTP streaming, suitable for docker-compose deployment).
MCP_TRANSPORT=sse

# Bind address and port for SSE/HTTP mode. Ignored for stdio.
MCP_HOST=0.0.0.0
MCP_PORT=8000

# OAuth2 / OpenID Connect settings (optional; required for HTTP transports)
# Authentik example: https://auth.hworthlab.cloud
OAUTH_ISSUER_URL=
# OAuth client ID from your OIDC provider
OAUTH_CLIENT_ID=
# OAuth client secret from your OIDC provider
OAUTH_CLIENT_SECRET=
# Full URL where the server is accessible (for OAuth callback)
# e.g., https://mealiemcp.hworthlab.cloud/mcp
OAUTH_SERVER_URL=
