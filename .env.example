# Base URL of your Mealie instance (no trailing slash).
# Local Docker example:    http://localhost:9011
# docker-compose service:  http://mealie:9000
MEALIE_URL=http://localhost:9011

# Long-lived API token. Create one in the Mealie UI under
# User Profile -> API Tokens.
MEALIE_API_TOKEN=replace-me

# Transport for the MCP server. "stdio" (Claude Desktop subprocess) or
# "sse" (HTTP streaming, suitable for docker-compose deployment).
MCP_TRANSPORT=sse

# Bind address and port for SSE/HTTP mode. Ignored for stdio.
MCP_HOST=0.0.0.0
MCP_PORT=8000

# OAuth2 / OpenID Connect settings (optional; recommended for HTTP transports).
#
# The MCP server is a protected resource only. The client (e.g. ChatGPT) runs
# the OAuth flow directly against your provider; the MCP server validates
# Bearer tokens against the issuer's JWKS.

# Application-specific issuer URL. For Authentik this is the URL of the
# Application's OAuth2/OpenID Provider, e.g.:
#   https://auth.hworthlab.cloud/application/o/mealie-mcp-auth/
# It must match the `iss` claim that your provider mints into tokens. The
# bare host root (e.g. https://auth.hworthlab.cloud) will NOT work.
OAUTH_ISSUER_URL=

# OAuth client ID from your provider.
OAUTH_CLIENT_ID=

# OAuth client secret. Optional. Leave blank when your provider's client type
# is Public/PKCE (the recommended config for ChatGPT). Only set this if your
# client is Confidential AND your MCP client passes the secret itself.
OAUTH_CLIENT_SECRET=

# Public URL of this MCP server, including the /mcp path, e.g.:
#   https://mealiemcp.hworthlab.cloud/mcp
# Advertised as the "resource" in /.well-known/oauth-protected-resource.
OAUTH_SERVER_URL=

# Note: register the redirect URI shown by your MCP client (e.g. ChatGPT's
# connector setup screen) in your provider's allowed redirect URIs. The MCP
# server itself does not host a /oauth/callback endpoint.
