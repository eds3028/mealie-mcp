# Base URL of your Mealie instance (no trailing slash).
# Local Docker example:    http://localhost:9011
# docker-compose service:  http://mealie:9000
MEALIE_URL=http://localhost:9011

# Long-lived API token. Create one in the Mealie UI under
# User Profile -> API Tokens.
MEALIE_API_TOKEN=replace-me

# Transport for the MCP server. "stdio" (Claude Desktop subprocess) or
# "sse" (HTTP streaming, suitable for docker-compose deployment).
# Default: "sse"
MCP_TRANSPORT=sse

# Bind address and port for SSE/HTTP mode. Ignored for stdio.
MCP_HOST=0.0.0.0
MCP_PORT=8000

# OAuth2 / OpenID Connect configuration (required for Claude and OpenAI connector auth)
# Leave blank to disable OAuth authentication.

# OIDC issuer URL (e.g., Authentik: https://auth.example.com)
OAUTH_ISSUER_URL=

# OAuth client ID from your OIDC provider
OAUTH_CLIENT_ID=

# OAuth client secret from your OIDC provider (keep secret!)
OAUTH_CLIENT_SECRET=

# Full URL where the MCP server is accessible (for OAuth callback).
# e.g., https://mealie-mcp.example.com or https://example.com/mcp
OAUTH_SERVER_URL=

# Optional: JWKS URI. If set, this overrides OIDC discovery.
# Only needed if OIDC discovery fails.
# OAUTH_JWKS_URI=https://auth.example.com/oauth/discovery/jwks/

# Optional: comma-separated list of allowed hostnames (DNS rebinding protection).
# Only used with HTTP transports.
# MCP_ALLOWED_HOSTS=mealie-mcp.example.com,localhost

# Optional: comma-separated list of allowed CORS origins.
# Only used with HTTP transports.
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://chat.openai.com
